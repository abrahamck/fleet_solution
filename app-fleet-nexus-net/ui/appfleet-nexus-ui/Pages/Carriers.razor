@page "/carriers"
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Top Carriers - FleetNexus</PageTitle>

<div class="container mt-5">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-sm">
            <h1 class="display-5 fw-bold text-dark">Top Carriers</h1>
            <p class="lead text-muted mb-0">View the top 10 carriers by number of power units</p>
        </div>
        <div class="col-sm-auto">
            <a href="/" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Home
            </a>
        </div>
    </div>

    @if (loading)
    {
        <!-- Premium skeleton loading state -->
        <div class="premium-table-container">
            <div class="skeleton-row">
                <div class="skeleton-item"></div>
                <div class="skeleton-item"></div>
                <div class="skeleton-item"></div>
                <div class="skeleton-item"></div>
                <div class="skeleton-item"></div>
            </div>
        </div>
    }
    else if (error)
    {
        <!-- Premium error state -->
        <div class="premium-empty-state">
            <div class="premium-empty-icon">
                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
            </div>
            <h3 class="premium-empty-title">Failed to Load Carriers</h3>
            <p class="premium-empty-desc">@errorMessage</p>
            <div class="row w-100 justify-content-center mt-2">
                <div class="col-auto">
                    <button class="auth-btn px-4" @onclick="ReloadData">
                        <i class="bi bi-arrow-clockwise"></i> Try Again
                    </button>
                </div>
            </div>
        </div>
    }
    else if (carriers != null && carriers.Count > 0)
    {
        <!-- Success State: Premium Table Card -->
        <div class="row mb-3">
            <div class="col">
                <span class="badge badge-brand-cobalt px-3 py-2">Total: @carriers.Count carriers</span>
            </div>
        </div>

        <div class="premium-table-container">
            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th scope="col">
                                <i class="bi bi-hash"></i> DOT Number
                            </th>
                            <th scope="col">
                                <i class="bi bi-building"></i> Legal Name
                            </th>
                            <th scope="col">
                                <i class="bi bi-geo-alt"></i> City
                            </th>
                            <th scope="col">
                                <i class="bi bi-map"></i> State
                            </th>
                            <th scope="col" class="text-end">
                                <i class="bi bi-truck"></i> Power Units
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var carrier in carriers)
                        {
                            <tr>
                                <td>
                                    <strong>@carrier.DotNumber</strong>
                                </td>
                                <td>@(carrier.LegalName ?? string.Empty)</td>
                                <td>@(carrier.City ?? string.Empty)</td>
                                <td>@(carrier.State ?? string.Empty)</td>
                                <td class="text-end">
                                    <span class="badge badge-brand-green px-3 py-2">@(carrier.NumberOfPowerUnits ?? 0)</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <!-- Premium Empty State -->
        <div class="premium-empty-state">
            <div class="premium-empty-icon">
                <i class="bi bi-truck text-muted"></i>
            </div>
            <h3 class="premium-empty-title">No Carriers Found</h3>
            <p class="premium-empty-desc">There are no carrier records matching your search or current view.</p>
            <div class="row w-100 justify-content-center mt-2">
                <div class="col-auto">
                    <button class="auth-secondary-btn px-4" @onclick="ReloadData">
                        <i class="bi bi-arrow-clockwise"></i> Refresh Data
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<CarrierDto>? carriers;
    private bool loading = true;
    private bool error = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
    }

    private async Task ReloadData()
    {
        try
        {
            loading = true;
            error = false;
            errorMessage = string.Empty;

            var response = await Http.GetAsync("api/carriers/top");
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse>();
                carriers = result?.Data ?? new List<CarrierDto>();
            }
            else
            {
                error = true;
                errorMessage = $"HTTP {response.StatusCode}: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            error = true;
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    public class ApiResponse
    {
        public bool Success { get; set; }
        public int Count { get; set; }
        public List<CarrierDto> Data { get; set; } = new();
    }

    public class CarrierDto
    {
        public long DotNumber { get; set; }
        public string? LegalName { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public int? NumberOfPowerUnits { get; set; }
    }
}
