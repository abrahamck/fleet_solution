@page "/"

<PageTitle>Home - FleetNexus</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold">Welcome to FleetNexus</h1>
                <p class="lead text-muted">The future for small and medium fleets</p>
            </div>

            <div class="row mt-5">
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="bi bi-truck display-4 text-primary"></i>
                            </div>
                            <h5 class="card-title">Fleet Management</h5>
                            <p class="card-text text-muted">Manage your fleet efficiently with our comprehensive tools and analytics.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="bi bi-bar-chart display-4 text-success"></i>
                            </div>
                            <h5 class="card-title">Analytics</h5>
                            <p class="card-text text-muted">Get insights into your fleet's performance with detailed reports and metrics.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5 mb-5">
                <a href="/carriers" class="btn btn-primary btn-lg">
                    View Top Carriers
                </a>
            </div>

            <div class="row mt-5">
                <div class="col-12">
                    <div class="card bg-light border-0">
                        <div class="card-body">
                            <h5 class="card-title">About FleetNexus</h5>
                            <p class="card-text">
                                FleetNexus is a modern fleet management solution designed for small and medium-sized businesses.
                                Built with the latest .NET technologies and industry best practices, FleetNexus helps you manage
                                your fleet more efficiently, reduce costs, and improve operational efficiency.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
