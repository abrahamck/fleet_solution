@page "/inventory"
@attribute [Authorize]
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>Inventory - FleetNexus</PageTitle>

<div class="inventory-container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="display-6 fw-bold text-dark mb-1">Inventory Management</h1>
            <p class="text-muted mb-0">Manage your company's vehicles and key directory contacts.</p>
        </div>
        <div>
            @if (_activeTab == "vehicles")
            {
                <button class="btn btn-primary d-flex align-items-center gap-2 px-4 py-2 shadow-sm" @onclick="OpenAddVehicleModal">
                    <i class="bi bi-plus-lg"></i> Add Vehicle
                </button>
            }
        </div>
    </div>

    <!-- Tabs Navigation -->
    <div class="inventory-tabs mb-4">
        <button class="tab-btn @(_activeTab == "vehicles" ? "active" : "")" @onclick='() => SetActiveTab("vehicles")'>
            <i class="bi bi-truck me-2"></i> Vehicles
            @if (_vehicles != null && !_isLoading)
            {
                <span class="badge bg-secondary ms-2 bg-opacity-25 text-secondary">@_vehicles.Count</span>
            }
        </button>
        <button class="tab-btn @(_activeTab == "contacts" ? "active" : "")" @onclick='() => SetActiveTab("contacts")'>
            <i class="bi bi-people me-2"></i> Contacts <span class="badge-soon ms-2">Coming Soon</span>
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @if (_activeTab == "vehicles")
        {
            <!-- Vehicles Content Section -->
            <div class="inventory-content-card shadow-sm p-4 mb-4">
                
                <!-- Filter Bar -->
                <div class="row g-3 mb-4 align-items-center">
                    <!-- Search -->
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control border-start-0 ps-0" placeholder="Search by Unit, VIN, Plate..." 
                                   @bind="_searchQuery" @bind:event="oninput" />
                        </div>
                    </div>
                    
                    <!-- Status Filter -->
                    <div class="col-sm-6 col-md-3">
                        <div class="d-flex align-items-center gap-2">
                            <label class="form-label mb-0 text-muted small text-nowrap">Status:</label>
                            <select class="form-select" @bind="_statusFilter">
                                <option value="All">All Statuses</option>
                                <option value="Active">Active</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <!-- Type Filter -->
                    <div class="col-sm-6 col-md-3">
                        <div class="d-flex align-items-center gap-2">
                            <label class="form-label mb-0 text-muted small text-nowrap">Type:</label>
                            <select class="form-select" @bind="_typeFilter">
                                <option value="All">All Types</option>
                                <option value="Truck">Truck</option>
                                <option value="Trailer">Trailer</option>
                                <option value="Van">Van</option>
                                <option value="Sedan">Sedan</option>
                                <option value="SUV">SUV</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    <!-- Reset Filters -->
                    <div class="col-auto ms-auto">
                        @if (!string.IsNullOrEmpty(_searchQuery) || _statusFilter != "All" || _typeFilter != "All")
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetFilters">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> Clear Filters
                            </button>
                        }
                    </div>
                </div>

                <!-- Vehicles List View -->
                @if (FilteredVehicles.Any())
                {
                    <!-- Desktop Grid (Table) -->
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Unit #</th>
                                    <th>Type</th>
                                    <th>Make & Model</th>
                                    <th>Year</th>
                                    <th>VIN</th>
                                    <th>Plate</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vehicle in FilteredVehicles)
                                {
                                    <tr>
                                        <td><strong>@vehicle.UnitNumber</strong></td>
                                        <td>@vehicle.Type</td>
                                        <td>@(string.IsNullOrWhiteSpace(vehicle.Make) && string.IsNullOrWhiteSpace(vehicle.Model) ? "—" : $"{vehicle.Make} {vehicle.Model}")</td>
                                        <td>@(vehicle.Year?.ToString() ?? "—")</td>
                                        <td><code class="small text-secondary">@(vehicle.Vin ?? "—")</code></td>
                                        <td>@(string.IsNullOrWhiteSpace(vehicle.LicensePlate) ? "—" : $"{vehicle.LicensePlate} ({vehicle.LicenseState})")</td>
                                        <td>
                                            <span class="badge-status badge-@(vehicle.Status.ToLower())">
                                                @vehicle.Status
                                            </span>
                                        </td>
                                        <td class="text-end text-nowrap">
                                            <button class="btn btn-sm btn-icon me-1" @onclick="() => EditVehicle(vehicle)" title="Edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </button>
                                            <button class="btn btn-sm btn-icon text-danger" @onclick="() => DeleteVehicle(vehicle.Id)" title="Delete">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Mobile Stacked Card List -->
                    <div class="mobile-card-list">
                        @foreach (var vehicle in FilteredVehicles)
                        {
                            <div class="vehicle-mobile-card">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h5 class="fw-bold text-dark mb-0">Unit @vehicle.UnitNumber</h5>
                                        <span class="text-muted small">@vehicle.Type</span>
                                    </div>
                                    <span class="badge-status badge-@(vehicle.Status.ToLower())">
                                        @vehicle.Status
                                    </span>
                                </div>
                                <div class="row g-2 mb-3 small text-muted border-top pt-2">
                                    <div class="col-6">
                                        <strong>Specs:</strong> @(string.IsNullOrWhiteSpace(vehicle.Make) && string.IsNullOrWhiteSpace(vehicle.Model) ? "—" : $"{vehicle.Make} {vehicle.Model}") @(vehicle.Year.HasValue ? $"({vehicle.Year})" : "")
                                    </div>
                                    <div class="col-6">
                                        <strong>Plate:</strong> @(string.IsNullOrWhiteSpace(vehicle.LicensePlate) ? "—" : $"{vehicle.LicensePlate} ({vehicle.LicenseState})")
                                    </div>
                                    <div class="col-12">
                                        <strong>VIN:</strong> <code class="small text-secondary">@(vehicle.Vin ?? "—")</code>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end gap-2 border-top pt-2">
                                    <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" @onclick="() => EditVehicle(vehicle)">
                                        <i class="bi bi-pencil-fill"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1" @onclick="() => DeleteVehicle(vehicle.Id)">
                                        <i class="bi bi-trash3-fill"></i> Delete
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="empty-state-icon mb-3">🔍</div>
                        <h4 class="fw-semibold text-dark">No Vehicles Found</h4>
                        <p class="text-muted max-width-400 mx-auto">We couldn't find any vehicles matching your search or filters. Adjust your criteria or add a new vehicle.</p>
                    </div>
                }

            </div>
        }
        else if (_activeTab == "contacts")
        {
            <!-- Contacts Placeholder -->
            <div class="inventory-content-card shadow-sm p-5 text-center">
                <div class="empty-state-icon mb-3">🪪</div>
                <h3 class="fw-bold text-dark">Contact Directory</h3>
                <p class="text-muted max-width-500 mx-auto">A directory mapping for customers, dispatch vendors, and drivers will live here. This will let you link drivers directly to vehicles and manage service partnerships.</p>
                <button class="btn btn-primary mt-3 px-4 py-2" @onclick='() => SetActiveTab("vehicles")'>
                    <i class="bi bi-arrow-left me-2"></i> Return to Vehicles
                </button>
            </div>
        }
    }
</div>

<!-- Add/Edit Dialog Component -->
<VehicleDialog IsVisible="_showModal"
               Vehicle="_activeModel"
               IsSubmitting="_isSaving"
               ErrorMessage="@_modalErrorMessage"
               OnSave="HandleSaveVehicle"
               OnCancel="CloseModal" />

@code {
    private string _activeTab = "vehicles";
    private bool _isLoading = true;
    private List<VehicleDto> _vehicles = new();
    
    // Filters state
    private string _searchQuery = "";
    private string _statusFilter = "All";
    private string _typeFilter = "All";

    // Modal state
    private bool _showModal = false;
    private bool _isSaving = false;
    private string? _modalErrorMessage;
    private VehicleDto _activeModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadVehiclesAsync();
    }

    private async Task LoadVehiclesAsync()
    {
        _isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<VehicleDto>>("api/vehicles");
            if (response != null)
            {
                _vehicles = response;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading vehicles: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IEnumerable<VehicleDto> FilteredVehicles
    {
        get
        {
            return _vehicles.Where(v => 
                (string.IsNullOrEmpty(_searchQuery) || 
                 v.UnitNumber.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                 (v.Vin?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                 (v.Make?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                 (v.Model?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                 (v.LicensePlate?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)) &&
                (_statusFilter == "All" || v.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase)) &&
                (_typeFilter == "All" || (v.Type?.Equals(_typeFilter, StringComparison.OrdinalIgnoreCase) ?? false))
            );
        }
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    private void ResetFilters()
    {
        _searchQuery = "";
        _statusFilter = "All";
        _typeFilter = "All";
    }

    private void OpenAddVehicleModal()
    {
        _activeModel = new VehicleDto();
        _modalErrorMessage = null;
        _showModal = true;
    }

    private void EditVehicle(VehicleDto vehicle)
    {
        // Deep clone properties so inline changes don't display in list if user cancels
        _activeModel = new VehicleDto
        {
            Id = vehicle.Id,
            UnitNumber = vehicle.UnitNumber,
            Vin = vehicle.Vin,
            Make = vehicle.Make,
            Model = vehicle.Model,
            Year = vehicle.Year,
            LicensePlate = vehicle.LicensePlate,
            LicenseState = vehicle.LicenseState,
            Type = vehicle.Type,
            Status = vehicle.Status
        };
        _modalErrorMessage = null;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _modalErrorMessage = null;
    }

    private async Task HandleSaveVehicle(VehicleDto vehicle)
    {
        _isSaving = true;
        _modalErrorMessage = null;

        try
        {
            HttpResponseMessage response;
            if (vehicle.Id == Guid.Empty)
            {
                response = await Http.PostAsJsonAsync("api/vehicles", vehicle);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/vehicles/{vehicle.Id}", vehicle);
            }

            if (response.IsSuccessStatusCode)
            {
                _showModal = false;
                await LoadVehiclesAsync();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(errorText);
                    if (doc.RootElement.TryGetProperty("message", out var msgProp))
                    {
                         _modalErrorMessage = msgProp.GetString();
                    }
                    else if (doc.RootElement.TryGetProperty("errors", out var errorsProp))
                    {
                         // Extract MVC Validation errors if any
                         _modalErrorMessage = "Validation failed. Please verify your inputs.";
                    }
                    else
                    {
                        _modalErrorMessage = "Failed to save the vehicle. Please check inputs.";
                    }
                }
                catch
                {
                    _modalErrorMessage = "Failed to save the vehicle. Please check inputs.";
                }
            }
        }
        catch (Exception ex)
        {
            _modalErrorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteVehicle(Guid id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this vehicle from your inventory?");
        if (confirmed)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/vehicles/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await LoadVehiclesAsync();
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Failed to delete the vehicle.");
                }
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"An error occurred while deleting: {ex.Message}");
            }
        }
    }
}
