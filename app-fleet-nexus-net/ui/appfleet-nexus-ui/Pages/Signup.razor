@page "/signup"
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject CustomAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Create Account - FleetNexus</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card" style="max-width: 480px;">
        <div class="text-center mb-4">
            <h2 class="auth-title mb-2">Get Started</h2>
            <p class="auth-subtitle">Create a free account for your fleet</p>
        </div>

        <!-- Progress Tracker (5 Steps) -->
        <div class="step-tracker-container">
            @for (int i = 1; i <= 5; i++)
            {
                var stepNum = i;
                <div class="step-indicator @(_currentStep == stepNum ? "active" : _currentStep > stepNum ? "completed" : "")">
                    <div class="step-dot"></div>
                </div>
                @if (stepNum < 5)
                {
                    <div class="step-connector @(_currentStep > stepNum ? "completed" : "")"></div>
                }
            }
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-modern alert-modern-danger mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>@_errorMessage</div>
            </div>
        }

        <EditForm Model="_signupModel">
            <DataAnnotationsValidator />

            @if (_currentStep == 1)
            {
                <!-- STEP 1: EMAIL ADDRESS -->
                <div class="fade-in">
                    <AuthInput @bind-Value="_signupModel.Email" 
                               Id="input-email"
                               Title="What is your email address?"
                               Label="We'll use this email as your username to log in."
                               Placeholder="name@example.com" 
                               Type="email"
                               InputMode="email"
                               Autocapitalize="none"
                               Autocorrect="off"
                               Error="@_emailError"
                               @onkeyup="HandleKeyUp" />
                </div>
            }
            else if (_currentStep == 2)
            {
                <!-- STEP 2: FIRST NAME -->
                <div class="fade-in">
                    <AuthInput @bind-Value="_signupModel.FirstName" 
                               Id="input-firstname"
                               Title="What is your first name?"
                               Label="We'll use this to personalize your experience."
                               Placeholder="Jane" 
                               Error="@_firstNameError"
                               @onkeyup="HandleKeyUp" />
                </div>
            }
            else if (_currentStep == 3)
            {
                <!-- STEP 3: LAST NAME -->
                <div class="fade-in">
                    <AuthInput @bind-Value="_signupModel.LastName" 
                               Id="input-lastname"
                               Title="What is your last name?"
                               Label="Please enter your last name for profile records."
                               Placeholder="Doe" 
                               Error="@_lastNameError"
                               @onkeyup="HandleKeyUp" />
                </div>
            }
            else if (_currentStep == 4)
            {
                <!-- STEP 4: PASSWORD -->
                <div class="fade-in">
                    <AuthInput @bind-Value="_signupModel.Password" 
                               Id="input-password"
                               Title="Choose a password"
                               Label="Make sure it's at least 6 characters long."
                               Placeholder="Minimum 6 characters" 
                               Type="password"
                               Error="@_passwordError"
                               @onkeyup="HandleKeyUp" />
                </div>
            }
            else if (_currentStep == 5)
            {
                <!-- STEP 5: RE-ENTER PASSWORD -->
                <div class="fade-in">
                    <AuthInput @bind-Value="_signupModel.ConfirmPassword" 
                               Id="input-confirm-password"
                               Title="Verify your password"
                               Label="Please re-type your password to confirm."
                               Placeholder="Re-enter password" 
                               Type="password"
                               Disabled="@_isSubmitting"
                               Error="@_confirmPasswordError"
                               @onkeyup="HandleKeyUp" />
                </div>
            }

            <!-- Navigation Buttons -->
            <div class="row g-2 mt-4">
                <div class="col-6">
                    <button type="button" class="btn btn-outline-secondary w-100 h-100" 
                            style="border-radius: 10px; min-height: 48px;" 
                            @onclick="GoBack" 
                            disabled="@(_currentStep == 1 || _isSubmitting)">
                        <i class="bi bi-arrow-left me-1"></i> Previous
                    </button>
                </div>
                <div class="col-6">
                    @if (_currentStep == 5)
                    {
                        <button type="button" class="auth-btn" @onclick="HandleSignup" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="btn-spinner"></span>
                                <span>Submitting...</span>
                            }
                            else
                            {
                                <span>Submit</span>
                                <i class="bi bi-check-circle"></i>
                            }
                        </button>
                    }
                    else
                    {
                        <button type="button" class="auth-btn" @onclick="GoNext">
                            <span>Next</span>
                            <i class="bi bi-arrow-right"></i>
                        </button>
                    }
                </div>
            </div>
        </EditForm>

        <div class="auth-divider">or</div>

        <div class="text-center">
            <span class="text-muted">Already have an account? </span>
            <a href="login" class="auth-link">Sign in instead</a>
        </div>
    </div>
</div>

@code {
    private readonly SignupModel _signupModel = new();
    private int _currentStep = 1;
    private bool _isSubmitting;
    private string? _errorMessage;

    // Field-specific validation errors
    private string? _emailError;
    private string? _firstNameError;
    private string? _lastNameError;
    private string? _passwordError;
    private string? _confirmPasswordError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FocusStepInput();
        }
    }

    private async Task FocusStepInput()
    {
        var inputId = _currentStep switch
        {
            1 => "input-email",
            2 => "input-firstname",
            3 => "input-lastname",
            4 => "input-password",
            5 => "input-confirm-password",
            _ => null
        };

        if (inputId != null)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", $"setTimeout(function() {{ document.getElementById('{inputId}')?.focus(); }}, 100);");
            }
            catch
            {
                // Fail silently if DOM is not ready
            }
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (_currentStep == 5)
            {
                await HandleSignup();
            }
            else
            {
                await GoNext();
            }
        }
    }

    private async Task GoNext()
    {
        bool isValid = _currentStep switch
        {
            1 => ValidateStep1(),
            2 => ValidateStep2(),
            3 => ValidateStep3(),
            4 => ValidateStep4(),
            _ => false
        };

        if (isValid)
        {
            _currentStep++;
            StateHasChanged();
            await FocusStepInput();
        }
    }

    private async Task GoBack()
    {
        if (_currentStep > 1)
        {
            _currentStep--;
            StateHasChanged();
            await FocusStepInput();
        }
    }

    private bool ValidateStep1()
    {
        _emailError = null;
        var results = new List<ValidationResult>();
        var context = new ValidationContext(_signupModel) { MemberName = nameof(SignupModel.Email) };
        bool isValid = Validator.TryValidateProperty(_signupModel.Email, context, results);
        if (!isValid)
        {
            _emailError = results.FirstOrDefault()?.ErrorMessage;
        }
        return isValid;
    }

    private bool ValidateStep2()
    {
        _firstNameError = null;
        var results = new List<ValidationResult>();
        var context = new ValidationContext(_signupModel) { MemberName = nameof(SignupModel.FirstName) };
        bool isValid = Validator.TryValidateProperty(_signupModel.FirstName, context, results);
        if (!isValid)
        {
            _firstNameError = results.FirstOrDefault()?.ErrorMessage;
        }
        return isValid;
    }

    private bool ValidateStep3()
    {
        _lastNameError = null;
        var results = new List<ValidationResult>();
        var context = new ValidationContext(_signupModel) { MemberName = nameof(SignupModel.LastName) };
        bool isValid = Validator.TryValidateProperty(_signupModel.LastName, context, results);
        if (!isValid)
        {
            _lastNameError = results.FirstOrDefault()?.ErrorMessage;
        }
        return isValid;
    }

    private bool ValidateStep4()
    {
        _passwordError = null;
        var results = new List<ValidationResult>();
        var context = new ValidationContext(_signupModel) { MemberName = nameof(SignupModel.Password) };
        bool isValid = Validator.TryValidateProperty(_signupModel.Password, context, results);
        if (!isValid)
        {
            _passwordError = results.FirstOrDefault()?.ErrorMessage;
        }
        return isValid;
    }

    private bool ValidateStep5()
    {
        _confirmPasswordError = null;
        var results = new List<ValidationResult>();
        var context = new ValidationContext(_signupModel) { MemberName = nameof(SignupModel.ConfirmPassword) };
        bool isValid = Validator.TryValidateProperty(_signupModel.ConfirmPassword, context, results);
        if (!isValid)
        {
            _confirmPasswordError = results.FirstOrDefault()?.ErrorMessage;
        }
        return isValid;
    }

    private async Task HandleSignup()
    {
        if (!ValidateStep5())
        {
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var request = new SignupRequest(
                _signupModel.Email, 
                _signupModel.Password, 
                _signupModel.FirstName, 
                _signupModel.LastName
            );
            var response = await Http.PostAsJsonAsync("api/auth/signup", request);

            if (response.IsSuccessStatusCode)
            {
                var authResult = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (authResult != null)
                {
                    var session = new UserSession(
                        authResult.AccessToken,
                        authResult.RefreshToken,
                        authResult.Email,
                        authResult.UserId
                    );
                    await AuthProvider.LoginAsync(session);
                    Navigation.NavigateTo("/");
                }
                else
                {
                    _errorMessage = "Account created successfully, but auto-login failed. Please sign in manually.";
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                try
                {
                    using var doc = JsonDocument.Parse(errorContent);
                    if (doc.RootElement.TryGetProperty("message", out var messageProp))
                    {
                        _errorMessage = messageProp.GetString();
                    }
                    else
                    {
                        _errorMessage = "Could not register account. Email might already be in use.";
                    }
                }
                catch
                {
                    _errorMessage = "Could not register account. Please check your credentials.";
                }
            }
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
